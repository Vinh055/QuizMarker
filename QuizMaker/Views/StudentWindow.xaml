<Window x:Class="QuizMaker.Views.StudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuizMaker.Views"
        mc:Ignorable="d"
        Title="StudentWindow" Height="750" Width="1000">
    <Grid>
        <Grid x:Name="GridStudentDashboard" Background="White" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="LblStudentWelcome" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="Danh sách bài kiểm tra:" Margin="0,0,0,5" Grid.Row="1" VerticalAlignment="Top"/>

            <DataGrid x:Name="DgStudentQuizzes" Grid.Row="1" Margin="0,30,0,10" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên bài" Binding="{Binding Title}" Width="2*"/>
                    <DataGridTextColumn Header="Giới hạn giờ?" Binding="{Binding HasTimeLimit}" Width="1*"/>
                    <DataGridTextColumn Header="Mở lúc" Binding="{Binding OpenTime, StringFormat=dd/MM/yyyy HH:mm}" Width="1.5*"/>
                    <DataGridTextColumn Header="Đóng lúc" Binding="{Binding CloseTime, StringFormat=dd/MM/yyyy HH:mm}" Width="1.5*"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="1.5*"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Đăng xuất" Width="120" Padding="10" Margin="0,0,15,0" Click="BtnLogout_Click"/>
                <Button Content="Xem kết quả/Đáp án" Width="160" Padding="10" Margin="0,0,15,0" Click="BtnViewStudentResult_Click" Background="#FFC107" FontWeight="Bold"/>
                <Button Content="Vào làm bài" Width="160" Padding="10" Click="BtnStartQuiz_Click" Background="#28A745" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="GridStudentResultDetails" Visibility="Collapsed" Background="White" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="CHI TIẾT BÀI LÀM" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock x:Name="LblStudentScoreDetail" FontSize="18" FontWeight="Bold" Foreground="#D83B01" HorizontalAlignment="Center"/>
            </StackPanel>

            <DataGrid x:Name="DgStudentAnswers" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,20">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Câu hỏi" Binding="{Binding QuestionTitle}" Width="1*"/>
                    <DataGridTextColumn Header="Bạn chọn" Binding="{Binding SelectedOption}" Width="1*"/>
                    <DataGridTextColumn Header="Đáp án đúng" Binding="{Binding CorrectOption}" Width="1*"/>
                    <DataGridCheckBoxColumn Header="Đúng/Sai" Binding="{Binding IsCorrect, Mode=OneWay}" Width="0.8*"/>
                </DataGrid.Columns>
            </DataGrid>

            <Button Grid.Row="2" Content="Quay lại Dashboard" Width="200" Padding="10" Click="BtnBackToStudentDash_Click" Background="#007ACC" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
